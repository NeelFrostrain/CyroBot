{
  "name": "cyrobot",
  "module": "./src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "bun run clear && bun run build && node build/index.js",
    "dev": "nodemon --watch src --ext ts,js,json --exec \"bun src/index.ts\"",
    "build": "tsc -p tsconfig.json",
    "clear": "rm -rf build"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "nodemon": "^3.1.10"
  },
  "peerDependencies": {
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@discordjs/voice": "discordjs/voice",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.2"
  }
}